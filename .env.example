# Back-end environment variables for Railway/local development.
# Copy to .env locally, or import these names in Railway and fill real values there.
GROQ_API_KEY=your_groq_api_key_here

# CORS allow-list for the browser front-end. Use the EXACT origin (scheme + host,
# no trailing slash, no path). On Railway set this to your Vercel URL, e.g.
#   FRONTEND_ORIGIN=https://your-app.vercel.app
# Multiple origins can be comma-separated, e.g.
#   FRONTEND_ORIGIN=https://your-app.vercel.app,https://www.yourdomain.com
# Any *.vercel.app deployment is also allowed automatically. localhost is always allowed.
FRONTEND_ORIGIN=http://localhost:3000

# Optional: improves Hugging Face download limits during Railway cold starts.
HF_TOKEN=your_hugging_face_token_here

# Optional: set false only if you want the first /api/options request to trigger loading.
PRELOAD_DATA_ON_STARTUP=true
